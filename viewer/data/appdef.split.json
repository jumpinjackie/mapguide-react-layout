{
    "Title": "Split View Demo",
    "MapSet": {
        "MapGroup": [
            {
                "@id": "Australia",
                "Extension": {
                    "SwipePrimary": "true",
                    "SwipePairWith": "AustraliaCompare"
                },
                "Map": [
                    {
                        "Type": "SubjectLayer",
                        "Extension": {
                            "source_type": "GeoJSON_Inline",
                            "display_name": "Australian Capital Cities",
                            "source_param_features": {
                                "type": "FeatureCollection",
                                "features": [
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [151.2093, -33.8688] },
                                        "properties": { "name": "Sydney", "state": "New South Wales", "population": 5312000, "role": "Largest city" }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [144.9631, -37.8136] },
                                        "properties": { "name": "Melbourne", "state": "Victoria", "population": 5078000, "role": "Capital of Victoria" }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [153.0251, -27.4698] },
                                        "properties": { "name": "Brisbane", "state": "Queensland", "population": 2514000, "role": "Capital of Queensland" }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [115.8575, -31.9505] },
                                        "properties": { "name": "Perth", "state": "Western Australia", "population": 2059000, "role": "Capital of Western Australia" }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [138.6007, -34.9285] },
                                        "properties": { "name": "Adelaide", "state": "South Australia", "population": 1345000, "role": "Capital of South Australia" }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [147.3272, -42.8821] },
                                        "properties": { "name": "Hobart", "state": "Tasmania", "population": 228000, "role": "Capital of Tasmania" }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [130.8456, -12.4634] },
                                        "properties": { "name": "Darwin", "state": "Northern Territory", "population": 147000, "role": "Capital of Northern Territory" }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [149.1300, -35.2809] },
                                        "properties": { "name": "Canberra", "state": "ACT", "population": 454000, "role": "National Capital" }
                                    }
                                ]
                            },
                            "source_param_attributions": [],
                            "meta_extents": [
                                113.34,
                                -43.63,
                                153.57,
                                -10.67
                            ],
                            "meta_projection": "EPSG:4326",
                            "is_selectable": true,
                            "popup_template": {
                                "title": "{name}",
                                "propertyMappings": [
                                    { "name": "state", "value": "State / Territory" },
                                    { "name": "role", "value": "Role" },
                                    { "name": "population", "value": "Population" }
                                ]
                            },
                            "vector_layer_style": {
                                "default": {
                                    "point": {
                                        "type": "Circle",
                                        "fill": {
                                            "color": "#ff6600",
                                            "alpha": 255
                                        },
                                        "radius": 8,
                                        "stroke": {
                                            "color": "#cc3300",
                                            "alpha": 255,
                                            "width": 2
                                        }
                                    }
                                }
                            }
                        }
                    },
                    {
                        "Type": "OpenStreetMap",
                        "Extension": {
                            "Options": {
                                "name": "Open Street Map",
                                "type": "Mapnik"
                            }
                        }
                    }
                ]
            },
            {
                "@id": "AustraliaCompare",
                "Map": [
                    {
                        "Type": "SubjectLayer",
                        "Extension": {
                            "source_type": "GeoJSON_Inline",
                            "display_name": "Australian Natural Landmarks",
                            "source_param_features": {
                                "type": "FeatureCollection",
                                "features": [
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [145.8000, -16.3000] },
                                        "properties": { "name": "Great Barrier Reef", "type": "Marine Park", "world_heritage": "Yes", "area_km2": 344400 }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [131.0369, -25.3444] },
                                        "properties": { "name": "Uluru-Kata Tjuta", "type": "National Park", "world_heritage": "Yes", "area_km2": 1326 }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [150.3000, -33.7000] },
                                        "properties": { "name": "Blue Mountains", "type": "National Park", "world_heritage": "Yes", "area_km2": 2680 }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [132.5000, -12.8000] },
                                        "properties": { "name": "Kakadu National Park", "type": "National Park", "world_heritage": "Yes", "area_km2": 19804 }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [145.4166, -16.1699] },
                                        "properties": { "name": "Daintree Rainforest", "type": "National Park", "world_heritage": "Yes", "area_km2": 1200 }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [143.4000, -38.8000] },
                                        "properties": { "name": "Great Ocean Road", "type": "Scenic Coastline", "world_heritage": "No", "area_km2": null }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [113.7500, -22.7000] },
                                        "properties": { "name": "Ningaloo Reef", "type": "Marine Park", "world_heritage": "Yes", "area_km2": 604500 }
                                    },
                                    {
                                        "type": "Feature",
                                        "geometry": { "type": "Point", "coordinates": [145.5000, -10.5000] },
                                        "properties": { "name": "Cape York Peninsula", "type": "Wilderness Area", "world_heritage": "No", "area_km2": 137000 }
                                    }
                                ]
                            },
                            "source_param_attributions": [],
                            "meta_extents": [
                                113.34,
                                -43.63,
                                153.57,
                                -10.67
                            ],
                            "meta_projection": "EPSG:4326",
                            "is_selectable": true,
                            "popup_template": {
                                "title": "{name}",
                                "propertyMappings": [
                                    { "name": "type", "value": "Type" },
                                    { "name": "world_heritage", "value": "World Heritage" },
                                    { "name": "area_km2", "value": "Area (km²)" }
                                ]
                            },
                            "vector_layer_style": {
                                "default": {
                                    "point": {
                                        "type": "Circle",
                                        "fill": {
                                            "color": "#00aa44",
                                            "alpha": 255
                                        },
                                        "radius": 8,
                                        "stroke": {
                                            "color": "#006622",
                                            "alpha": 255,
                                            "width": 2
                                        }
                                    }
                                }
                            }
                        }
                    },
                    {
                        "Type": "OpenStreetMap",
                        "Extension": {
                            "Options": {
                                "name": "Open Street Map",
                                "type": "Mapnik"
                            }
                        }
                    }
                ]
            }
        ]
    },
